<form action="/login" method="post" class="auth-form">
  <h2>Login</h2>
  <input
    type="email"
    name="username"
    value="<%=formData.email || '' %>"
    placeholder="* Email"
    required
  />
  <input type="password" name="password" placeholder="* Password" required />
  <a href="/recover" class="auth-link"> Forget your password ? </a>
  <div class="info-box">
    <%-include("../partials/errors") %>
    <small class="message"><%=locals.message%></small>
  </div>
  <button type="submit">Login</button>
  <a href="/register" class="auth-link"> Don't have account yet </a>
</form>
