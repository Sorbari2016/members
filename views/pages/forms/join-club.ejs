<%-include("../../partials/head") %>
<form action="/users/<%=user.id %>/join-club" method="post" class="auth-form">
  <h2>Become a Club Member</h2>
  <input
    type="password"
    name="passcode"
    id="passcode"
    placeholder="* Passcode"
    required
  />
  <div class="info-box">
    <%-include("../../partials/errors") %>
    <small class="message"><%=locals.message%></small>
  </div>
  <button type="submit">Join the club</button>
  <a href="/" class="btn btn-cancel">Go back</a>
</form>
